    "version": "npm run stage:version-files",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "openclaw": "2026.3.24"
  },
  "engines": {
    "node": ">=22"
  }
}
